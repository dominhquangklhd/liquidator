@startuml Strategy Module - Sequence Diagram

skinparam backgroundColor #FAFAFA
skinparam sequenceMessageAlign center
skinparam sequence {
    ArrowColor #8E44AD
    LifeLineBorderColor #8E44AD
    ParticipantBorderColor #8E44AD
    ParticipantBackgroundColor #FBF0FF
    BoxBackgroundColor #F5F5F5
    BoxBorderColor #CCCCCC
}

title <b>Strategy Module</b>\nSequence Diagram — create_execution_plan() Flow

' ── Participants ─────────────────────────────────────
box "Caller" #FFF8E7
    participant "Executor\nWorker" as EW
end box

box "Strategy Module" #FBF0FF
    participant "StrategyDecider\n.create_plan()" as SD
    participant "CircuitBreaker\n(RwLock)" as CB
    participant "Scoring\nEngine" as SE
end box

box "Shared State" #F5FFF0
    participant "wallet_balance_eth\n(RwLock<f64>)" as WB
    participant "current_gas_gwei\n(RwLock<f64>)" as GP
    participant "StrategyStats\n(RwLock)" as Stats
end box

' ── Main Flow ─────────────────────────────────────────
EW -> SD : create_execution_plan(\n  targets: &[LiquidationTarget],\n  estimates: &[ProfitEstimate]\n)
activate SD

' Step 1: Check Circuit Breaker
SD -> CB : read_lock().await
activate CB
CB -> SD  : CircuitBreaker { is_tripped, tripped_at, ... }
deactivate CB

alt Circuit Breaker đang tripped
    SD -> CB  : Kiểm tra elapsed(tripped_at)
    alt Cooldown hết (≥ 60s)
        SD -> CB : write_lock → is_tripped = false\n              consecutive_failures = 0
        SD -> SD : log INFO "Circuit breaker reset"
    else Vẫn trong cooldown
        SD -> Stats : skip_count += targets.len()
        SD -> EW    : ExecutionPlan { decisions: [], method: Skip }
        note right of EW
          Không thực hiện gì cả
          Chờ đến khi cooldown hết
        end note
        return
    end
end

' Step 2: Check Gas Price
SD -> GP : read_lock().await
GP -> SD  : current_gas_gwei: f64  (VD: 25.0)

alt Gas price > max_gas_gwei (config)
    SD -> Stats : skip_count += targets.len()
    SD -> EW    : ExecutionPlan với tất cả Skip\n(reason: "gas too high: 250 gwei")
    return
end

' Step 3: Prioritize targets
SD -> SE : prioritize(targets, estimates)
activate SE

loop Với mỗi (target_i, estimate_i)

    SE -> SE : Kiểm tra estimate_i.is_profitable
    alt Không profitable
        SE -> SE : decision = Skip\nreason = "unprofitable"
        note over SE
          VD: net_profit = -$2.5
          → bỏ qua target này
        end note
    else Profitable

        note over SE
          <b>Multi-Factor Scoring:</b>
          Chuẩn hóa từng factor về [0, 1]:
            profit_norm   = net / max_net_in_batch
            urgency_norm  = (1/HF) chuẩn hóa
            roi_norm      = roi / max_roi
            size_norm     = (1/debt) chuẩn hóa
          
          score = 0.40×profit + 0.35×urgency
                + 0.15×roi   + 0.10×size
        end note

        SE -> SE : score = compute_score(estimate, target)
        SE -> SE : Đưa vào danh sách prioritized
    end
end

SE -> SE : Sort by score DESC
SE -> SD  : Vec<PrioritizedTarget> { target, score, rank }
deactivate SE

' Step 4: Decide execution method for each target
SD -> WB : read_lock().await
WB -> SD  : wallet_balance_eth: f64

loop Với mỗi prioritized_target (theo rank)

    SD -> SD : wallet_tokens_usd = estimate(wallet)\nvs debt_to_cover_usd

    alt flash_loan_available && debt_to_cover > min_flash_loan
        alt Wallet không đủ debt token
            SD -> SD : decision = FlashLoan
            note over SD
              Dùng flash loan khi:
              - Vốn không đủ để cover debt
              - Hoặc debt quá lớn
              Flash loan fee: 0.05%
            end note
        else Wallet đủ
            SD -> SD : decision = Direct
        end
    else Flash loan không available
        alt Wallet đủ token
            SD -> SD : decision = Direct
        else Wallet không đủ
            SD -> SD : decision = Skip\nreason = "insufficient funds,\nno flash loan"
        end
    end

    SD -> SD : Thêm StrategyDecision vào plan\n(max max_concurrent decisions)
    note over SD
      Giới hạn số lượng concurrent
      liquidations theo config
      (mặc định: 3)
    end note

end

' Step 5: Build plan & update stats
SD -> Stats : write_lock().await
Stats -> SD  : &mut StrategyStats
SD -> Stats : total_decisions += N\ndirect_count += D\nflash_loan_count += F\nskip_count += S\ntotal_plans += 1

SD -> EW : ExecutionPlan {\n  decisions: Vec<StrategyDecision>,\n  total_estimated_profit_usd,\n  total_gas_budget\n}
deactivate SD

note over EW
  Executor Worker nhận plan và
  thực thi lần lượt từng decision
  theo thứ tự priority.
end note

@enduml
