@startuml Risk Engine - Sequence Diagram

skinparam backgroundColor #FAFAFA
skinparam sequenceMessageAlign center
skinparam sequence {
    ArrowColor #2D7DD2
    ActorBorderColor #D4A017
    LifeLineBorderColor #2D7DD2
    ParticipantBorderColor #2D7DD2
    ParticipantBackgroundColor #EEF7FF
    ActorBackgroundColor #FFF3CD
    BoxBackgroundColor #F5F5F5
    BoxBorderColor #CCCCCC
}

title <b>Risk Engine Module</b>\nSequence Diagram — Xử lý Price Update Event

' ── Participants ─────────────────────────────────────
box "External / Background Workers" #FFF8E7
    participant "Oracle\nPrice Worker" as OraclePW
    participant "Block\nWatcher" as BlockW
end box

box "Event Bus (MPSC Channel)" #F0F8FF
    participant "Event\nChannel" as Channel
end box

box "Risk Engine" #F0FFF0
    participant "RiskEngine\n(run loop)" as RE
    participant "HealthFactor\nCalculator" as HFC
    participant "RiskBucket\nClassifier" as RBC
end box

box "Data Layer" #FFF0F5
    participant "User Registry\n(DashMap)" as Registry
    participant "Asset Map\n(DashMap)" as AssetMap
end box

box "Storage" #F5F5F5
    participant "HybridStorage\n(Hot Cache)" as HotCache
end box

' ── Main Flow ─────────────────────────────────────────
== Khởi động hệ thống ==

OraclePW  -> OraclePW : Khởi tạo Chainlink feeds\n& đọc giá ban đầu
BlockW    -> BlockW   : Bắt đầu lắng nghe blocks mới
RE        -> RE       : Vào run() loop — chờ events

== Luồng xử lý Price Update ==

OraclePW  -> Channel  : send(Event::PriceUpdate {\n  asset_id: "ETH",\n  new_price: 2450.0\n})
activate Channel

RE        -> Channel  : recv()
Channel   -> RE       : Event::PriceUpdate
deactivate Channel

activate RE

RE        -> AssetMap : get_mut("ETH")
AssetMap  -> RE       : &mut Asset
RE        -> AssetMap : asset.price_in_eth = 2450.0
note right of RE : Cập nhật giá tài sản\ntrong DashMap

RE        -> Registry : get_users_for_asset("ETH")
Registry  -> RE       : Vec<UserId> [user_001, user_002, ...]
note right of RE : Lấy danh sách users\nbị ảnh hưởng bởi ETH

RE        -> AssetMap : snapshot tất cả assets\n→ HashMap (tránh lock qua .await)
AssetMap  -> RE       : HashMap<AssetId, Asset>

loop Với mỗi user_id bị ảnh hưởng

    RE        -> Registry : get_mut(user_id)
    Registry  -> RE       : &mut User {collateral, debt, ...}

    RE        -> HFC      : calculate(&user, &asset_snapshot)
    activate HFC
    HFC       -> HFC      : Σ(collateral_i × price_i × LT_i)
    HFC       -> HFC      : Σ(debt_i × price_i)
    HFC       -> HFC      : HF = Collateral×LT / Total_Debt
    HFC       -> RE       : new_hf: f64
    deactivate HFC

    RE        -> RBC      : from_hf(new_hf)
    activate RBC
    RBC       -> RE       : new_bucket: RiskBucket
    deactivate RBC

    RE        -> RE       : user.health_factor = new_hf\nuser.risk_bucket = new_bucket

    alt Bucket thay đổi (old != new)
        RE -> RE : log WARN — "User X: Safe → Danger (HF: 1.05)"
    end

    alt HF < 1.3 (tiệm cận ngưỡng thanh lý)
        RE -> RE : Tính total_collateral_usd\n& total_debt_usd\n& ltv\n& risk_score
        RE -> HotCache : upsert_target(LiquidationTarget {\n  user_address,\n  health_factor,\n  total_collateral_usd,\n  risk_score, ...\n})
        note right of HotCache
            HF < 1.0 → Liquidate
            1.0–1.1 → Danger
            1.1–1.3 → Warning
            Chỉ HF < 1.0 sẽ được
            Executor Worker xử lý
        end note
    end

end

deactivate RE

== Luồng Block Event ==

BlockW    -> Channel  : send(Event::Block {\n  block_number: 19_500_123\n})
RE        -> Channel  : recv()
Channel   -> RE       : Event::Block
activate RE
RE        -> RE       : log "Block #19_500_123"
note right of RE : Block events dùng\ncho future features\n(e.g. timestamp checks)
deactivate RE

@enduml
