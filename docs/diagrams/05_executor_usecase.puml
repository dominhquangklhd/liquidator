@startuml Executor Module - Use Case Diagram

skinparam backgroundColor #FAFAFA
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam usecase {
    BackgroundColor #FFF0F0
    BorderColor #E74C3C
    ArrowColor #E74C3C
}
skinparam actor {
    BackgroundColor #F0F7FF
    BorderColor #2D7DD2
}

title <b>Executor Module</b>\nUse Case Diagram

left to right direction

' ── Actors ──────────────────────────────────────────
actor "HotCache\n(Storage)" as HotCache
actor "Profit\nCalculator" as PC
actor "Strategy\nDecider" as SD
actor "Aave Pool\nContract" as AavePool
actor "ERC20 Token\nContract" as ERC20
actor "HybridStorage\n(History)" as Storage
actor "Nonce Manager\n(On-chain)" as NonceManager

' ── System boundary ─────────────────────────────────
rectangle "Executor Module" {

    usecase "UC-EX01\nVòng lặp chính\nExecutor Worker" as UC_EX01
    usecase "UC-EX02\nLấy Top Targets\ntừ HotCache" as UC_EX02
    usecase "UC-EX03\nLọc targets\n(HF < 1.0)" as UC_EX03
    usecase "UC-EX04\nĐánh giá\nLợi nhuận" as UC_EX04
    usecase "UC-EX05\nLấy Nonce\nhiện tại" as UC_EX05
    usecase "UC-EX06\nApprove ERC20\nToken" as UC_EX06
    usecase "UC-EX07\nThực hiện\nDirect Liquidation" as UC_EX07
    usecase "UC-EX08\nThực hiện\nFlash Loan\nLiquidation" as UC_EX08
    usecase "UC-EX09\nChờ Tx\nReceipt" as UC_EX09
    usecase "UC-EX10\nGhi lịch sử\nLiquidationEvent" as UC_EX10
    usecase "UC-EX11\nXử lý thất bại\n& Retry" as UC_EX11
    usecase "UC-EX12\nBáo cáo\nThống kê" as UC_EX12
    usecase "UC-EX13\nXác thực on-chain\n(getUserAccountData)" as UC_EX13

}

' ── Relationships ────────────────────────────────────
HotCache     --> UC_EX02
PC           --> UC_EX04
SD           --> UC_EX01 : ExecutionPlan
NonceManager --> UC_EX05
ERC20        --> UC_EX06
AavePool     --> UC_EX07
AavePool     --> UC_EX08
Storage      --> UC_EX10

UC_EX01 ..> UC_EX02 : <<include>>
UC_EX02 ..> UC_EX03 : <<include>>
UC_EX03 ..> UC_EX04 : <<include>>
UC_EX04 ..> UC_EX13 : <<include>>
UC_EX04 ..> UC_EX05 : <<include>>\n[profitable]
UC_EX05 ..> UC_EX06 : <<include>>
UC_EX06 ..> UC_EX07 : <<extend>>\n[Direct method]
UC_EX06 ..> UC_EX08 : <<extend>>\n[Flash Loan method]
UC_EX07 ..> UC_EX09 : <<include>>
UC_EX08 ..> UC_EX09 : <<include>>
UC_EX09 ..> UC_EX10 : <<include>>\n[tx confirmed]
UC_EX09 ..> UC_EX11 : <<extend>>\n[tx failed / timeout]
UC_EX11 ..> UC_EX10 : <<include>>\n[failure event]
UC_EX01 ..> UC_EX12 : <<include>>

note right of UC_EX07
  <b>Direct Liquidation:</b>
  1. approve(AavePool, debt_amount)
  2. liquidationCall(
       collateralAsset,
       debtAsset,
       user,
       debtToCover,
       receiveAToken=false
     )
end note

note right of UC_EX08
  <b>Flash Loan:</b>
  Vay token từ Aave v3 flash loan
  → Dùng để cover debt
  → Nhận collateral + bonus
  → Trả lại flash loan + 0.05% fee
  (Triển khai future work)
end note

note bottom of UC_EX13
  <b>On-chain Validation:</b>
  Gọi getUserAccountData() trước khi
  submit tx để đảm bảo HF vẫn < 1.0
  (tránh race condition với tx khác)
end note

@enduml
