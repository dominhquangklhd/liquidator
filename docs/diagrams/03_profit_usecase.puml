@startuml Profit Module - Use Case Diagram

skinparam backgroundColor #FAFAFA
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam usecase {
    BackgroundColor #F0FFF4
    BorderColor #27AE60
    ArrowColor #27AE60
}
skinparam actor {
    BackgroundColor #FFF9E6
    BorderColor #F39C12
}

title <b>Profit Module</b>\nUse Case Diagram

left to right direction

' ── Actors ──────────────────────────────────────────
actor "Executor\nWorker" as ExecutorW
actor "Oracle Module\n(Price Cache)" as Oracle
actor "Blockchain\n(Gas Estimator)" as Blockchain

' ── System boundary ─────────────────────────────────
rectangle "Profit Module" {

    usecase "UC-PR01\nĐánh giá\nLợi nhuận\n(evaluate)" as UC_PR01
    usecase "UC-PR02\nKiểm tra\nHF < 1.0" as UC_PR02
    usecase "UC-PR03\nLấy Giá\ntừ Oracle Cache" as UC_PR03
    usecase "UC-PR04\nTìm Cặp\nCollateral / Debt\nKhả thi" as UC_PR04
    usecase "UC-PR05\nChọn Cặp\nTối Ưu\n(max score)" as UC_PR05
    usecase "UC-PR06\nTính Gross\nProfit" as UC_PR06
    usecase "UC-PR07\nTính Chi Phí\nGas (USD)" as UC_PR07
    usecase "UC-PR08\nTính\nSlippage" as UC_PR08
    usecase "UC-PR09\nTính\nFlash Loan Fee" as UC_PR09
    usecase "UC-PR10\nTính Net\nProfit" as UC_PR10
    usecase "UC-PR11\nQuyết định\nKhả thi\n(profitable?)" as UC_PR11
    usecase "UC-PR12\nBáo cáo\nThống kê" as UC_PR12

}

' ── Relationships ────────────────────────────────────
ExecutorW  --> UC_PR01
Oracle     --> UC_PR03 : price_cache (shared\nRwLock<HashMap>)
Blockchain --> UC_PR07 : eth_gasPrice()

UC_PR01 ..> UC_PR02 : <<include>>
UC_PR01 ..> UC_PR03 : <<include>>
UC_PR01 ..> UC_PR04 : <<include>>
UC_PR04 ..> UC_PR05 : <<include>>
UC_PR05 ..> UC_PR06 : <<include>>
UC_PR06 ..> UC_PR07 : <<include>>
UC_PR06 ..> UC_PR08 : <<include>>
UC_PR06 ..> UC_PR09 : <<extend>>\n[flash loan được dùng]
UC_PR07 ..> UC_PR10 : <<include>>
UC_PR08 ..> UC_PR10 : <<include>>
UC_PR10 ..> UC_PR11 : <<include>>
UC_PR01 ..> UC_PR12 : <<include>>

note right of UC_PR06
  <b>Công thức:</b>
  debt_to_cover = total_debt × close_factor (50%)
  collateral_received = debt_to_cover × (1 + bonus%)
  gross_profit = collateral_received - debt_to_cover
               = debt_to_cover × bonus%
end note

note right of UC_PR10
  <b>Net Profit:</b>
  net = gross_profit
      - gas_cost_usd
      - slippage_cost
      - flash_loan_fee (nếu có)

  <b>Chấp nhận nếu:</b>
  net ≥ min_profit_usd ($5)
  ROI ≥ min_roi_pct (1%)
end note

note bottom of UC_PR05
  <b>Scoring cặp:</b>
  score = gross_profit
        × (1 - slippage%)
        - gas_cost
  → Chọn cặp có score cao nhất
end note

@enduml
