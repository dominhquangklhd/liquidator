@startuml
skinparam packageStyle rectangle
skinparam backgroundColor #FFFFFF
skinparam usecase {
    BackgroundColor #E2EAF4
    BorderColor #2C3E50
    ArrowColor #2C3E50
    FontName Arial
}

left to right direction

actor "RPC Provider" as RPC

rectangle "UC02: Phản hồi sự kiện biến động vị thế người dùng" {

    usecase "Phản hồi sự kiện biến động vị thế người dùng" as UC02

    usecase "Tiếp nhận và giải mã sự kiện\ntừ hợp đồng thông minh" as Sub1
    usecase "Cập nhật số dư ví\nvào lớp lưu trữ" as Sub2
    usecase "Tính toán lại hệ số sức khỏe\ncủa ví bị ảnh hưởng" as Sub3

    usecase "Kích hoạt luồng\nthực thi thanh lý (UC04)" as Sub4
    usecase "Ghi nhận trạng thái\nan toàn vào cơ sở dữ liệu" as Ext1

    usecase "Bỏ qua sự kiện\nkhông hợp lệ hoặc lỗi thời" as Ext2
}

RPC --> Sub1 : "Phát sự kiện\nbiến động vị thế"

UC02 ..> Sub1 : <<include>>
UC02 ..> Sub2 : <<include>>
UC02 ..> Sub3 : <<include>>

Sub3 ..> Sub4 : <<extend>>\nNếu hệ số sức khỏe < 1
Ext1 .up.> Sub3 : <<extend>>\nNếu hệ số sức khỏe >= 1
Ext2 .up.> Sub1 : <<extend>>\nNếu sự kiện không hợp lệ\nhoặc khối quá cũ

@enduml
