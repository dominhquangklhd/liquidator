@startuml
skinparam packageStyle rectangle
skinparam backgroundColor #FFFFFF
skinparam usecase {
    BackgroundColor #E2EAF4
    BorderColor #2C3E50
    ArrowColor #2C3E50
    FontName Arial
}

left to right direction

actor "Liquidator Bot" as Bot
actor "RPC Provider" as RPC

rectangle "UC: Đồng bộ dữ liệu Lưu trữ" {

    usecase "Đồng bộ hóa và duy trì\ntính nhất quán dữ liệu" as UC11

    usecase "Tiếp nhận và trích xuất\ndữ liệu thực thể" as Sub1
    usecase "Chuẩn hóa dữ liệu\ntheo định dạng nội bộ" as Sub2
    usecase "Cập nhật dữ liệu vào\nHybrid Storage" as Sub3

    usecase "Khởi chạy dọn dẹp định kỳ\n(Storage Optimization)" as Ext1
    usecase "Ghi nhận lỗi và thử lại\n(Retry)" as Ext2
}

Bot --> UC11
RPC --> UC11 : "Cung cấp thay đổi trạng thái\ntừ mạng lưới blockchain"

' Các luồng sự kiện chính
UC11 ..> Sub1 : <<include>>
UC11 ..> Sub2 : <<include>>
UC11 ..> Sub3 : <<include>>

' Các luồng ngoại lệ / thay thế
Ext1 .down.> UC11 : <<extend>>\n(Đạt ngưỡng lưu trữ/Suy giảm hiệu suất)
Ext2 .down.> UC11 : <<extend>>\n(Lỗi ghi dữ liệu vào lưu trữ)

@enduml
