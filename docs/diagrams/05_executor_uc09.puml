@startuml
skinparam packageStyle rectangle
skinparam backgroundColor #FFFFFF
skinparam usecase {
    BackgroundColor #E2EAF4
    BorderColor #2C3E50
    ArrowColor #2C3E50
    FontName Arial
}

left to right direction

actor "Liquidator Bot" as Bot
actor "RPC Provider" as RPC

rectangle "UC: Thực thi giao dịch thanh lý" {
    
    usecase "Chuẩn bị và gửi\ngiao dịch thanh lý" as UC09
    
    usecase "Kiểm tra ràng buộc\nvà tạo Payload" as Sub1
    usecase "Mô phỏng thực thi\n(Estimate Gas)" as Sub2
    usecase "Ký và gửi giao dịch" as Sub3
    
    usecase "Khởi chạy giả lập\n(Dry-Run)" as Ext1
    usecase "Hủy do lỗi mô phỏng/\nThiếu điều kiện" as Ext2
}

Bot --> UC09
UC09 --> RPC : "Phát tán giao dịch"

' Các luồng sự kiện chính
UC09 ..> Sub1 : <<include>>
UC09 ..> Sub2 : <<include>>
UC09 ..> Sub3 : <<include>>

' Các luồng ngoại lệ / thay thế
Ext1 .down.> UC09 : <<extend>>\n(Chế độ giả lập mở)
Ext2 .down.> UC09 : <<extend>>\n(Mô phỏng Revert / Thiếu Gas / Lỗi RPC)

@enduml