@startuml
skinparam packageStyle rectangle
skinparam backgroundColor #FFFFFF
skinparam usecase {
    BackgroundColor #E2EAF4
    BorderColor #2C3E50
    ArrowColor #2C3E50
    FontName Arial
}

left to right direction

actor "Liquidator Bot" as Bot

rectangle "UC: Lựa chọn cặp tài sản" {
    
    usecase "Tính toán và lựa chọn\ncặp tài sản tối ưu" as UC08
    
    usecase "Trích xuất danh sách\ntài sản nợ & thế chấp" as Sub1
    usecase "Sinh cặp ứng viên &\nChấm điểm đa tiêu chí" as Sub2
    usecase "Lựa chọn cặp tối ưu\nvà chuyển kết quả" as Sub3
    
    usecase "Loại bỏ do rủi ro trượt giá\n(Slippage Constraint)" as Ext1
}

Bot --> UC08

' Các luồng sự kiện chính
UC08 ..> Sub1 : <<include>>
UC08 ..> Sub2 : <<include>>
UC08 ..> Sub3 : <<include>>

' Các luồng ngoại lệ / thay thế
Ext1 .down.> UC08 : <<extend>>\n(Vi phạm trượt giá/thanh khoản)

@enduml