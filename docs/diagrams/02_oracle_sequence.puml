@startuml Oracle Module - Sequence Diagram

skinparam backgroundColor #FAFAFA
skinparam sequenceMessageAlign center
skinparam sequence {
    ArrowColor #E07B39
    ActorBorderColor #1890FF
    LifeLineBorderColor #E07B39
    ParticipantBorderColor #E07B39
    ParticipantBackgroundColor #FFF0E6
    ActorBackgroundColor #E6F7FF
    BoxBackgroundColor #F5F5F5
    BoxBorderColor #CCCCCC
}

title <b>Oracle Module</b>\nSequence Diagram — Vòng đời Oracle Price Worker

' ── Participants ─────────────────────────────────────
box "Background Workers" #FFF8E7
    participant "Oracle\nPrice Worker" as PW
    participant "Oracle\nHealth Worker" as HW
    participant "Oracle\nStats Worker" as SW
end box

box "Oracle Manager" #FFF0E6
    participant "OracleManager" as OM
    participant "ChainlinkFeed\n(per asset)" as CF
end box

box "On-chain (Anvil/Mainnet)" #F0F4FF
    participant "Chainlink Feed\nContract" as Chainlink
end box

box "Internal State" #F5FFF0
    participant "price_cache\n(RwLock<HashMap>)" as Cache
    participant "feed_info\n(RwLock<HashMap>)" as FeedInfo
end box

box "Downstream" #FFF5F5
    participant "Event\nChannel" as Channel
end box

' ── Phase 1: Initialization ──────────────────────────
== Giai đoạn 1: Khởi tạo Feeds ==

[-> OM : OracleManager::new(config, provider, event_tx)
activate OM
OM -> OM : Tạo ChainlinkFeed cho mỗi feed_config\n(WETH, USDC, WBTC, ...)
OM -> FeedInfo : Khởi tạo PriceFeedInfo\n(status = Uninitialized)
[<-- OM : OracleManager instance
deactivate OM

[-> OM : oracle_manager.initialize()
activate OM
loop Với mỗi feed (ETH, USDC, WBTC, ...)
    OM    -> CF      : feed.initialize()
    activate CF
    CF    -> Chainlink : decimals() [view call]
    Chainlink -> CF  : 8
    CF    -> Chainlink : description() [view call]
    Chainlink -> CF  : "ETH / USD"
    CF    -> OM      : Ok(())
    deactivate CF

    OM    -> CF      : feed.latest_price()
    activate CF
    CF    -> Chainlink : latestRoundData()
    Chainlink -> CF  : (roundId, answer, startedAt,\nupdatedAt, answeredInRound)
    CF    -> CF      : Chuyển đổi answer / 10^decimals\n→ price_usd: f64
    CF    -> OM      : PriceData { price_usd: 2450.0, ... }
    deactivate CF

    OM    -> Cache   : cache.insert("ETH", PriceData)
    OM    -> FeedInfo : info.status = Active\ninfo.current_price = Some(price)
    OM    -> OM      : log "✓ ETH = $2450.00"
end
deactivate OM

== Giai đoạn 2: Oracle Price Worker Loop ==

[-> PW : oracle_price_worker(oracle, config)
activate PW
PW -> PW : ticker = interval(poll_interval_ms)

loop Mỗi poll_interval_ms (mặc định: 2000ms)
    PW -> PW : ticker.tick().await

    PW -> OM : oracle.poll_all_prices().await
    activate OM

    loop Với mỗi feed
        OM  -> CF      : feed.latest_price().await
        activate CF
        CF  -> Chainlink : latestRoundData()

        alt Chainlink trả về thành công
            Chainlink -> CF  : (roundId, answer, updatedAt, ...)
            CF  -> CF        : price = answer / 10^8
            CF  -> OM        : Ok(PriceData { price_usd })
            deactivate CF

            OM  -> Cache     : read old_price = cache["ETH"]

            alt Phát hiện price deviation
                note over OM
                  deviation = |new - old| / old
                  Nếu deviation ≥ 0.5% (0.005)
                  HOẶC elapsed > max_age_secs
                end note
                OM  -> Channel  : send(Event::PriceUpdate {\n  asset_id: "ETH",\n  new_price: 2455.0\n})
                note right of Channel
                  Risk Engine sẽ nhận event
                  này và tính lại HF của
                  tất cả users có ETH
                end note
            end

            OM  -> Cache     : cache.insert("ETH", new_price_data)
            OM  -> FeedInfo  : info.success_count += 1\ninfo.last_updated = now()

        else Chainlink call thất bại
            Chainlink --> CF  : Error (timeout / revert)
            CF  -> OM        : Err(...)
            deactivate CF
            OM  -> FeedInfo  : info.error_count += 1
            OM  -> OM        : log WARN fallback to cached price
        end
    end

    deactivate OM
end
deactivate PW

== Giai đoạn 3: Health Worker kiểm tra Feed Status ==

[-> HW : oracle_health_worker(oracle, config)
activate HW
HW -> HW : ticker = interval(health_check_interval_secs)

loop Mỗi health_check_interval_secs (mặc định: 300s)
    HW -> OM  : oracle.check_feed_health().await
    activate OM
    loop Với mỗi feed
        OM  -> FeedInfo : đọc last_updated, error_count
        alt Giá stale (elapsed > 3600s)
            OM  -> FeedInfo : info.status = Stale
            OM  -> OM       : log ERROR "Feed ETH stale!"
        else error_count nhiều
            OM  -> FeedInfo : info.status = Degraded
        end
    end
    deactivate OM
end
deactivate HW

@enduml
