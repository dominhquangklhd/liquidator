@startuml Strategy Module - Use Case Diagram

skinparam backgroundColor #FAFAFA
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam usecase {
    BackgroundColor #FBF0FF
    BorderColor #8E44AD
    ArrowColor #8E44AD
}
skinparam actor {
    BackgroundColor #FFF0E6
    BorderColor #E07B39
}

title <b>Strategy Module</b>\nUse Case Diagram

left to right direction

' ── Actors ──────────────────────────────────────────
actor "Executor\nWorker" as ExecutorW
actor "Profit\nCalculator" as ProfitCalc
actor "Blockchain\n(Gas Price)" as Blockchain

' ── System boundary ─────────────────────────────────
rectangle "Strategy Module (StrategyDecider)" {

    usecase "UC-ST01\nTạo Execution\nPlan" as UC_ST01
    usecase "UC-ST02\nƯu tiên hóa\nDanh sách Targets\n(Prioritize)" as UC_ST02
    usecase "UC-ST03\nTính\nMulti-Factor Score" as UC_ST03
    usecase "UC-ST04\nQuyết định\nDirect Liquidation" as UC_ST04
    usecase "UC-ST05\nBỏ qua Target\n(Skip)" as UC_ST05
    usecase "UC-ST07\nKiểm tra\nCircuit Breaker" as UC_ST07
    usecase "UC-ST08\nKiểm tra\nGas Price" as UC_ST08
    usecase "UC-ST09\nKiểm tra\nWallet Balance" as UC_ST09
    usecase "UC-ST10\nReset Circuit\nBreaker" as UC_ST10
    usecase "UC-ST11\nGhi nhận\nThất bại" as UC_ST11
    usecase "UC-ST12\nBáo cáo\nThống kê" as UC_ST12

}

' ── Relationships ────────────────────────────────────
ExecutorW  --> UC_ST01
ProfitCalc --> UC_ST02 : ProfitEstimate[]
Blockchain --> UC_ST08 : current gas price

UC_ST01 ..> UC_ST07 : <<include>>
UC_ST01 ..> UC_ST02 : <<include>>
UC_ST01 ..> UC_ST08 : <<include>>

UC_ST02 ..> UC_ST03 : <<include>>
UC_ST03 ..> UC_ST04 : <<extend>>\n[wallet đủ token\n& debt nhỏ]
UC_ST03 ..> UC_ST05 : <<extend>>\n[không profitable\nhoặc thiếu token\nhoặc debt lớn]

UC_ST09 ..> UC_ST04 : <<include>>

UC_ST11 ..> UC_ST07 : <<include>>\n[n failures >= threshold]
UC_ST10 ..> UC_ST07 : <<include>>\n[cooldown elapsed]
UC_ST12 ..> UC_ST01 : <<include>>

note right of UC_ST03
  <b>Multi-Factor Score:</b>
  score = w_profit   × norm(net_profit)
        + w_urgency  × norm(1 / HF)
        + w_efficiency × norm(ROI)
        + w_size     × norm(1 / debt_size)

  Trọng số (configurable):
  w_profit    = 0.40
  w_urgency   = 0.35
  w_efficiency = 0.15
  w_size      = 0.10
end note

note right of UC_ST07
  <b>Circuit Breaker:</b>
  Tripped nếu consecutive_failures
  ≥ threshold (mặc định 3)
  
  Cooldown: 60 giây
  Sau cooldown → auto reset
  
  Mục đích: tránh lặp lại giao
  dịch thất bại liên tiếp
end note

note bottom of UC_ST05
  <b>Skip điều kiện chính:</b>
  • Wallet không đủ debt token
  • debt_to_cover vượt direct_max_debt_usd
  • target không profitable
end note

@enduml
